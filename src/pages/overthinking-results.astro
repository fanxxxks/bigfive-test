---
import BaseLayout from '../layouts/BaseLayout.astro';
import OverthinkingResultsReport from '../components/OverthinkingResultsReport';
---

<BaseLayout
  title="精神内耗指数报告"
  description="你的精神内耗测评报告——5维度雷达图、四种内耗类型匹配度与反内耗策略。"
>
  <main class="min-h-screen bg-gray-50 print:bg-white">
    <div class="max-w-4xl mx-auto px-4 py-8">
      <OverthinkingResultsReport client:only="react" />
    </div>
  </main>
</BaseLayout>

<style is:global>
  @media print { body { background: white !important; } .card { box-shadow: none !important; border: 1px solid #e5e7eb !important; } a, button { display: none !important; } .bg-gray-50 { background: white !important; } }
</style>
