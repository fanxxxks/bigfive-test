---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhilosophyQuizEngine from '../components/PhilosophyQuizEngine';
---

<BaseLayout title="哲学气质测评" description="60道题探索你的哲学气质——尼采、叔本华、孔子、庄子、萨特等18个哲学流派，看看你的思想属于谁？">
  <main class="min-h-screen bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 py-8">
      <PhilosophyQuizEngine client:load />
    </div>
  </main>
</BaseLayout>
