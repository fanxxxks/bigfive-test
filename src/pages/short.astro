---
import BaseLayout from '../layouts/BaseLayout.astro';
import ShortQuizEngine from '../components/ShortQuizEngine';
---

<BaseLayout title="大五人格（简洁版）" description="IPIP-50 简洁版大五人格测评 — 50道题、5-8分钟快速了解你的五大维度人格特质。">
  <main class="min-h-screen bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 py-8">
      <ShortQuizEngine client:load />
    </div>
  </main>
</BaseLayout>
