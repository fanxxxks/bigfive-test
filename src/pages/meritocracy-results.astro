---
import BaseLayout from '../layouts/BaseLayout.astro';
import MeritocracyResultsReport from '../components/MeritocracyResultsReport';
---

<BaseLayout
  title="优绩主义程度报告"
  description="你的优绩主义程度测评报告——6维度雷达图、四种类型匹配度与成功观深度解读。"
>
  <main class="min-h-screen bg-gray-50 print:bg-white">
    <div class="max-w-4xl mx-auto px-4 py-8">
      <MeritocracyResultsReport client:only="react" />
    </div>
  </main>
</BaseLayout>

<style is:global>
  @media print { body { background: white !important; } .card { box-shadow: none !important; border: 1px solid #e5e7eb !important; } a, button { display: none !important; } .bg-gray-50 { background: white !important; } }
</style>
