---
import BaseLayout from '../layouts/BaseLayout.astro';
import ValuesResultsReport from '../components/ValuesResultsReport';
---

<BaseLayout title="核心价值观报告" description="您的核心价值观测评报告 — 10种基本价值观排序、深度解读与生活应用建议。">
  <main class="min-h-screen bg-gray-50 print:bg-white">
    <div class="max-w-4xl mx-auto px-4 py-8">
      <ValuesResultsReport client:only="react" />
    </div>
  </main>
</BaseLayout>

<style is:global>
  @media print {
    body { background: white !important; }
    .card { box-shadow: none !important; border: 1px solid #e5e7eb !important; }
    a, button { display: none !important; }
    .bg-gray-50 { background: white !important; }
  }
</style>
