---
import BaseLayout from '../layouts/BaseLayout.astro';
import TemperamentResultsReport from '../components/TemperamentResultsReport';
---

<BaseLayout
  title="淡人/浓人气质报告"
  description="你的淡人/浓人气质鉴定结果——双维度象限分析、四种类型匹配度与深度个性解读。"
>
  <main class="min-h-screen bg-gray-50 print:bg-white">
    <div class="max-w-4xl mx-auto px-4 py-8">
      <TemperamentResultsReport client:only="react" />
    </div>
  </main>
</BaseLayout>

<style is:global>
  @media print {
    body { background: white !important; }
    .card { box-shadow: none !important; border: 1px solid #e5e7eb !important; }
    a, button { display: none !important; }
    .bg-gray-50 { background: white !important; }
  }
</style>
