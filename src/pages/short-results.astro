---
import BaseLayout from '../layouts/BaseLayout.astro';
import ShortResultsReport from '../components/ShortResultsReport';
---

<BaseLayout title="大五人格报告（简洁版）" description="您的大五人格科学测评报告（简洁版）— 五大维度深度分析与百分位排名。">
  <main class="min-h-screen bg-gray-50 print:bg-white">
    <div class="max-w-4xl mx-auto px-4 py-8">
      <ShortResultsReport client:only="react" />
    </div>
  </main>
</BaseLayout>

<style is:global>
  @media print {
    body { background: white !important; }
    .card { box-shadow: none !important; border: 1px solid #e5e7eb !important; }
    a, button { display: none !important; }
    .bg-gray-50 { background: white !important; }
  }
</style>
