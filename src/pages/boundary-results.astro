---
import BaseLayout from '../layouts/BaseLayout.astro';
import BoundaryResultsReport from '../components/BoundaryResultsReport';
---

<BaseLayout
  title="讨好型/不好惹指数报告"
  description="你的社交边界测评报告——双维度象限分析、四种类型匹配度与反精神内耗指南。"
>
  <main class="min-h-screen bg-gray-50 print:bg-white">
    <div class="max-w-4xl mx-auto px-4 py-8">
      <BoundaryResultsReport client:only="react" />
    </div>
  </main>
</BaseLayout>

<style is:global>
  @media print {
    body { background: white !important; }
    .card { box-shadow: none !important; border: 1px solid #e5e7eb !important; }
    a, button { display: none !important; }
    .bg-gray-50 { background: white !important; }
  }
</style>
