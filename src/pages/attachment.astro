---
import BaseLayout from '../layouts/BaseLayout.astro';
import AttachmentQuizEngine from '../components/AttachmentQuizEngine';
---

<BaseLayout title="依恋风格测评" description="36道题探索你的依恋风格——基于成人依恋理论，测量焦虑与回避两个维度，判断安全型/焦虑型/回避型/恐惧型。">
  <main class="min-h-screen bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 py-8">
      <AttachmentQuizEngine client:load />
    </div>
  </main>
</BaseLayout>
