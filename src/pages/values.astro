---
import BaseLayout from '../layouts/BaseLayout.astro';
import ValuesQuizEngine from '../components/ValuesQuizEngine';
---

<BaseLayout title="核心价值观测评" description="40道题探索你的核心价值观——基于Schwartz理论，测量权力、成就、享乐、自主等10种基本价值观的优先级。">
  <main class="min-h-screen bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 py-8">
      <ValuesQuizEngine client:load />
    </div>
  </main>
</BaseLayout>
