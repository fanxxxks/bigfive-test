---
import BaseLayout from '../layouts/BaseLayout.astro';
import DecisionResultsReport from '../components/DecisionResultsReport';
---

<BaseLayout title="决策风格报告" description="您的决策风格测评报告 — 4种决策风格排序、深度解读与改善建议。">
  <main class="min-h-screen bg-gray-50 print:bg-white">
    <div class="max-w-4xl mx-auto px-4 py-8">
      <DecisionResultsReport client:only="react" />
    </div>
  </main>
</BaseLayout>

<style is:global>
  @media print {
    body { background: white !important; }
    .card { box-shadow: none !important; border: 1px solid #e5e7eb !important; }
    a, button { display: none !important; }
    .bg-gray-50 { background: white !important; }
  }
</style>
