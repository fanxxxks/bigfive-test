---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhilosophyResultsReport from '../components/PhilosophyResultsReport';
---

<BaseLayout title="哲学气质报告" description="您的哲学气质测评报告 — 18大哲学流派匹配度分析、深度解读与思想气质合成。">
  <main class="min-h-screen bg-gray-50 print:bg-white">
    <div class="max-w-4xl mx-auto px-4 py-8">
      <PhilosophyResultsReport client:only="react" />
    </div>
  </main>
</BaseLayout>

<style is:global>
  @media print {
    body { background: white !important; }
    .card { box-shadow: none !important; border: 1px solid #e5e7eb !important; }
    a, button { display: none !important; }
    .bg-gray-50 { background: white !important; }
  }
</style>
